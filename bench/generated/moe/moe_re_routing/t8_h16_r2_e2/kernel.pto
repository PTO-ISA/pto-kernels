            %14 = arith.muli %arg8, %c2_0 : index
            %15 = arith.addi %14, %arg7 : index
            %16 = pto.load_scalar %arg5[%15] : !pto.ptr<i32> -> i32
            %17 = arith.index_cast %16 : i32 to index
            %18 = arith.addi %arg9, %17 : index
