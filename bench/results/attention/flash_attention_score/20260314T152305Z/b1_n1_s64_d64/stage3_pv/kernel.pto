        %c1_9 = arith.constant 1 : index
        %16 = arith.select %15, %c1_9, %13 : index
        %c0_10 = arith.constant 0 : index
        %17 = arith.select %15, %c0_10, %14 : index
        %c3 = arith.constant 3 : index
        %18 = arith.cmpi eq, %arg3, %c3 : index
        %c1_11 = arith.constant 1 : index
        %19 = arith.select %18, %c1_11, %16 : index
        %c1_12 = arith.constant 1 : index
        %20 = arith.select %18, %c1_12, %17 : index
        %c4 = arith.constant 4 : index
        %21 = arith.cmpi eq, %arg3, %c4 : index
        %c2_13 = arith.constant 2 : index
        %22 = arith.select %21, %c2_13, %19 : index
        %c0_14 = arith.constant 0 : index
        %23 = arith.select %21, %c0_14, %20 : index
        %c5 = arith.constant 5 : index
        %24 = arith.cmpi eq, %arg3, %c5 : index
        %c2_15 = arith.constant 2 : index
        %25 = arith.select %24, %c2_15, %22 : index
        %c1_16 = arith.constant 1 : index
        %26 = arith.select %24, %c1_16, %23 : index
        %c6 = arith.constant 6 : index
        %27 = arith.cmpi eq, %arg3, %c6 : index
        %c3_17 = arith.constant 3 : index
        %28 = arith.select %27, %c3_17, %25 : index
        %c0_18 = arith.constant 0 : index
        %29 = arith.select %27, %c0_18, %26 : index
        %c7 = arith.constant 7 : index
        %30 = arith.cmpi eq, %arg3, %c7 : index
        %c3_19 = arith.constant 3 : index
        %31 = arith.select %30, %c3_19, %28 : index
        %c1_20 = arith.constant 1 : index
        %32 = arith.select %30, %c1_20, %29 : index
        %33 = arith.muli %31, %c16 : index
        %34 = arith.muli %32, %c32 : index
        %35 = pto.partition_view %0, offsets = [%33, %c0], sizes = [%c16, %c32_2] : !pto.tensor_view<?x?xf16> -> !pto.partition_tensor_view<16x32xf16>
        %36 = pto.partition_view %1, offsets = [%c0, %34], sizes = [%c32_2, %c32] : !pto.tensor_view<?x?xf16> -> !pto.partition_tensor_view<32x32xf16>
        pto.tload ins(%35 : !pto.partition_tensor_view<16x32xf16>) outs(%7 : !pto.tile_buf<loc=mat, dtype=f16, rows=16, cols=32, v_row=16, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
        pto.tload ins(%36 : !pto.partition_tensor_view<32x32xf16>) outs(%8 : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
        pto.tmov ins(%7 : !pto.tile_buf<loc=mat, dtype=f16, rows=16, cols=32, v_row=16, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>) outs(%9 : !pto.tile_buf<loc=left, dtype=f16, rows=16, cols=32, v_row=16, v_col=32, blayout=row_major, slayout=row_major, fractal=512, pad=0>)
        pto.tmov ins(%8 : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>) outs(%10 : !pto.tile_buf<loc=right, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=col_major, fractal=512, pad=0>)
        pto.tmatmul ins(%9, %10 : !pto.tile_buf<loc=left, dtype=f16, rows=16, cols=32, v_row=16, v_col=32, blayout=row_major, slayout=row_major, fractal=512, pad=0>, !pto.tile_buf<loc=right, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=col_major, fractal=512, pad=0>) outs(%11 : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=32, v_row=16, v_col=32, blayout=col_major, slayout=row_major, fractal=1024, pad=0>)
        scf.for %arg4 = %c1 to %c2 step %c1 {
          %38 = arith.muli %arg4, %c32_2 : index
          %39 = pto.partition_view %0, offsets = [%33, %38], sizes = [%c16, %c32_2] : !pto.tensor_view<?x?xf16> -> !pto.partition_tensor_view<16x32xf16>
          %40 = pto.partition_view %1, offsets = [%38, %34], sizes = [%c32_2, %c32] : !pto.tensor_view<?x?xf16> -> !pto.partition_tensor_view<32x32xf16>
          pto.tload ins(%39 : !pto.partition_tensor_view<16x32xf16>) outs(%7 : !pto.tile_buf<loc=mat, dtype=f16, rows=16, cols=32, v_row=16, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
          pto.tload ins(%40 : !pto.partition_tensor_view<32x32xf16>) outs(%8 : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
          pto.tmov ins(%7 : !pto.tile_buf<loc=mat, dtype=f16, rows=16, cols=32, v_row=16, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>) outs(%9 : !pto.tile_buf<loc=left, dtype=f16, rows=16, cols=32, v_row=16, v_col=32, blayout=row_major, slayout=row_major, fractal=512, pad=0>)
          pto.tmov ins(%8 : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>) outs(%10 : !pto.tile_buf<loc=right, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=col_major, fractal=512, pad=0>)
          pto.tmatmul.acc ins(%11, %9, %10 : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=32, v_row=16, v_col=32, blayout=col_major, slayout=row_major, fractal=1024, pad=0>, !pto.tile_buf<loc=left, dtype=f16, rows=16, cols=32, v_row=16, v_col=32, blayout=row_major, slayout=row_major, fractal=512, pad=0>, !pto.tile_buf<loc=right, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=col_major, fractal=512, pad=0>) outs(%11 : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=32, v_row=16, v_col=32, blayout=col_major, slayout=row_major, fractal=1024, pad=0>)
        }
