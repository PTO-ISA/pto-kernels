        %c1_30 = arith.constant 1 : index
        %46 = arith.select %45, %c1_30, %43 : index
        %c4_31 = arith.constant 4 : index
        %47 = arith.select %45, %c4_31, %44 : index
        %c13 = arith.constant 13 : index
