        scf.for %arg4 = %c1 to %c8 step %c1 {
          %62 = arith.muli %arg4, %c16_2 : index
          %63 = pto.partition_view %0, offsets = [%57, %62], sizes = [%c16, %c16_2] : !pto.tensor_view<?x?xf16> -> !pto.partition_tensor_view<16x16xf16>
          %64 = pto.partition_view %1, offsets = [%62, %58], sizes = [%c16_2, %c16_1] : !pto.tensor_view<?x?xf16> -> !pto.partition_tensor_view<16x16xf16>
