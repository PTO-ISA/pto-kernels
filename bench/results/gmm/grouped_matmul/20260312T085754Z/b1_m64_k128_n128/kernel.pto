module {
  func.func @grouped_matmul_dense_bf16_bf16(%arg0: !pto.ptr<bf16>, %arg1: !pto.ptr<bf16>, %arg2: !pto.ptr<bf16>, %arg3: i32) {
    pto.section.cube {
      %c0 = arith.constant 0 : index
      %c1 = arith.constant 1 : index
      %c64 = arith.constant 64 : index
      %c128 = arith.constant 128 : index
      %c64_0 = arith.constant 64 : index
      %c2 = arith.constant 2 : index
      %c128_1 = arith.constant 128 : index
      %c128_2 = arith.constant 128 : index
      %0 = pto.make_tensor_view %arg1, shape = [%c64, %c128_1] strides = [%c128_2, %c1] : !pto.tensor_view<?x?xbf16>
      %c128_3 = arith.constant 128 : index
      %1 = pto.make_tensor_view %arg2, shape = [%c128_3, %c128] strides = [%c128, %c1] : !pto.tensor_view<?x?xbf16>
      %2 = pto.make_tensor_view %arg0, shape = [%c64, %c128] strides = [%c128, %c1] : !pto.tensor_view<?x?xbf16>
      %3 = pto.alloc_tile : !pto.tile_buf<loc=mat, dtype=bf16, rows=64, cols=64, v_row=64, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
      %4 = pto.alloc_tile : !pto.tile_buf<loc=mat, dtype=bf16, rows=64, cols=128, v_row=64, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>
      %5 = pto.alloc_tile : !pto.tile_buf<loc=left, dtype=bf16, rows=64, cols=64, v_row=64, v_col=64, blayout=row_major, slayout=row_major, fractal=512, pad=0>
      %6 = pto.alloc_tile : !pto.tile_buf<loc=right, dtype=bf16, rows=64, cols=128, v_row=64, v_col=128, blayout=row_major, slayout=col_major, fractal=512, pad=0>
      %7 = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=64, cols=128, v_row=64, v_col=128, blayout=col_major, slayout=row_major, fractal=1024, pad=0>
      scf.for %arg4 = %c0 to %c2 step %c1 {
        %9 = arith.muli %arg4, %c64_0 : index
        %10 = pto.partition_view %0, offsets = [%c0, %9], sizes = [%c64, %c64_0] : !pto.tensor_view<?x?xbf16> -> !pto.partition_tensor_view<64x64xbf16>
        %11 = pto.partition_view %1, offsets = [%9, %c0], sizes = [%c64_0, %c128] : !pto.tensor_view<?x?xbf16> -> !pto.partition_tensor_view<64x128xbf16>
        pto.tload ins(%10 : !pto.partition_tensor_view<64x64xbf16>) outs(%3 : !pto.tile_buf<loc=mat, dtype=bf16, rows=64, cols=64, v_row=64, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
        pto.tload ins(%11 : !pto.partition_tensor_view<64x128xbf16>) outs(%4 : !pto.tile_buf<loc=mat, dtype=bf16, rows=64, cols=128, v_row=64, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
        pto.tmov ins(%3 : !pto.tile_buf<loc=mat, dtype=bf16, rows=64, cols=64, v_row=64, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>) outs(%5 : !pto.tile_buf<loc=left, dtype=bf16, rows=64, cols=64, v_row=64, v_col=64, blayout=row_major, slayout=row_major, fractal=512, pad=0>)
        pto.tmov ins(%4 : !pto.tile_buf<loc=mat, dtype=bf16, rows=64, cols=128, v_row=64, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>) outs(%6 : !pto.tile_buf<loc=right, dtype=bf16, rows=64, cols=128, v_row=64, v_col=128, blayout=row_major, slayout=col_major, fractal=512, pad=0>)
        %12 = arith.cmpi eq, %arg4, %c0 : index
        scf.if %12 {
          pto.tmatmul ins(%5, %6 : !pto.tile_buf<loc=left, dtype=bf16, rows=64, cols=64, v_row=64, v_col=64, blayout=row_major, slayout=row_major, fractal=512, pad=0>, !pto.tile_buf<loc=right, dtype=bf16, rows=64, cols=128, v_row=64, v_col=128, blayout=row_major, slayout=col_major, fractal=512, pad=0>) outs(%7 : !pto.tile_buf<loc=acc, dtype=f32, rows=64, cols=128, v_row=64, v_col=128, blayout=col_major, slayout=row_major, fractal=1024, pad=0>)
        } else {
