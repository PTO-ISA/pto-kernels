      %7 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=256, v_row=1, v_col=256, blayout=row_major, slayout=none_box, fractal=512, pad=0>
      %8 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=256, v_row=1, v_col=256, blayout=row_major, slayout=none_box, fractal=512, pad=0>
      scf.for %arg5 = %c0 to %c32 step %c1 {
        %9 = arith.muli %arg5, %c256 : index
