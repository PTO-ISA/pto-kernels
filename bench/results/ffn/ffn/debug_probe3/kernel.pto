      pto.tstore ins(%11 : !pto.tile_buf<loc=acc, dtype=f32, rows=32, cols=256, v_row=32, v_col=256, blayout=col_major, slayout=row_major, fractal=1024, pad=0>) outs(%12 : !pto.partition_tensor_view<32x256xf16>)
